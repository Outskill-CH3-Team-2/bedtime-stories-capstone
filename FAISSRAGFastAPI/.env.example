# ── RAG Story Generator API — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── OpenAI Configuration ──────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use for story generation (gpt-4 recommended for best quality)
# Options: gpt-4, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4

# ── Embedding Configuration ───────────────────────────────────────────────────
# Local HuggingFace model — no API key needed, runs on CPU
# Downloaded automatically on first run (~90MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── File Storage ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
FAISS_STORE_DIR=./faiss_store

# ── Chunking Defaults ─────────────────────────────────────────────────────────
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50
DEFAULT_TOP_K=5
