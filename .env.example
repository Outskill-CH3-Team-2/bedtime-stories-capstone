# --- Ports ---
FRONTEND_PORT=3005
BACKEND_PORT=8081

# OpenRouter API Key for future integration
OPENROUTER_API_KEY=your_openrouter_key_here


# Set to true to wipe IndexedDB on app start (simulates a clean first-run)
VITE_DELETE_DB=false

# Set to a file path (relative to frontend/public/) of a test PNG to use instead
# of generating real images (saves API costs when testing story text only)
# Example: VITE_TEST_IMAGE=test_image.png
VITE_TEST_IMAGE=

# Set to a file path (relative to frontend/public/) of a test WAV to use instead
# of generating real audio (saves API costs when testing story text only)
# Example: VITE_TEST_AUDIO=test_audio.wav
VITE_TEST_AUDIO=

# Backend mock — set to true to skip all AI calls and return synthetic scene data
MOCK_PIPELINES=false

# Write debug artefacts (text/audio/image files) to backend/debug_output/
DEBUG=true
DEBUG_OUTPUT_DIR=TEMPDIR/storyweaver_debug
